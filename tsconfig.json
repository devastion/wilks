{
  "compilerOptions": {
    /* Base Options: */
    "esModuleInterop": true,
    "skipLibCheck": true,
    "target": "es2022",
    "allowJs": true,
    "resolveJsonModule": true,
    "moduleDetection": "force",
    "isolatedModules": true,

    /* Strictness */
    "strict": true,
    "noUncheckedIndexedAccess": true,

    /* Transpiling */
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationDir": "dist/dts",
    "lib": ["es2022"]
  },
  "include": ["src"]
}
